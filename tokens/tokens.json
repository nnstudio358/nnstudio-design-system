{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "$type": "color",
    "bg":       { "$value": "#EDECE8", "$description": "Page background, light section bg" },
    "ink":      { "$value": "#232520", "$description": "Headlines, body text, dark section bg" },
    "muted":    { "$value": "#8A8A82", "$description": "Nav links, labels, secondary text" },
    "faint":    { "$value": "#D6D2CA", "$description": "Card borders, dividers" },
    "rule":     { "$value": "#C8C2BA", "$description": "Horizontal rules, separators" },
    "amber":    { "$value": "#C8923A", "$description": "Primary CTA, eyebrows, bullet markers" },
    "amber-hover": { "$value": "#D4A55A", "$description": "Amber hover state" },
    "slate":    { "$value": "#2C3236", "$description": "Industry tags, secondary accent" },
    "offwhite": { "$value": "#F4F3EF", "$description": "Text on ink/dark sections" },
    "body-light": { "$value": "#6B6A63", "$description": "Body copy on light bg — inline use" },
    "body-dark":  { "$value": "#C8C2BA", "$description": "Body copy on dark/ink bg — inline use" },
    "ink-border": { "$value": "#252523", "$description": "Borders within ink sections" }
  },
  "font": {
    "$type": "fontFamily",
    "serif": { "$value": ["Playfair Display", "Georgia", "serif"] },
    "sans":  { "$value": ["DM Sans", "system-ui", "-apple-system", "sans-serif"] }
  },
  "fontSize": {
    "$type": "dimension",
    "hero":       { "$value": "76px", "$description": "Hero h1 desktop" },
    "hero-md":    { "$value": "56px", "$description": "Hero h1 tablet" },
    "hero-sm":    { "$value": "40px", "$description": "Hero h1 mobile" },
    "section":    { "$value": "52px", "$description": "Section h2 desktop" },
    "section-md": { "$value": "40px", "$description": "Section h2 tablet" },
    "section-sm": { "$value": "30px", "$description": "Section h2 mobile" },
    "pillar":     { "$value": "40px", "$description": "Pillar h3 desktop" },
    "pillar-md":  { "$value": "36px", "$description": "Pillar h3 tablet" },
    "pillar-sm":  { "$value": "32px", "$description": "Pillar h3 mobile" },
    "card":       { "$value": "18px" },
    "body-lg":    { "$value": "19px", "$description": "Body large desktop" },
    "body-lg-sm": { "$value": "17px", "$description": "Body large mobile" },
    "body-sm":    { "$value": "15px" },
    "nav":        { "$value": "13px" },
    "cta":        { "$value": "14px" },
    "eyebrow":    { "$value": "12px" },
    "tag":        { "$value": "11px" }
  },
  "fontWeight": {
    "light":   { "$value": "300" },
    "regular": { "$value": "400" },
    "medium":  { "$value": "500" }
  },
  "lineHeight": {
    "hero":    { "$value": "1.08" },
    "section": { "$value": "1.1" },
    "body":    { "$value": "1.65" }
  },
  "letterSpacing": {
    "tight":   { "$value": "-0.02em", "$description": "All headings" },
    "nav":     { "$value": "0.04em",  "$description": "Nav links, CTA buttons" },
    "eyebrow": { "$value": "0.12em",  "$description": "Uppercase labels" }
  },
  "spacing": {
    "$type": "dimension",
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "9":  { "$value": "36px" },
    "10": { "$value": "40px" },
    "14": { "$value": "56px" },
    "16": { "$value": "64px" },
    "24": { "$value": "96px" },
    "30": { "$value": "120px" }
  },
  "layout": {
    "maxWidth":      { "$value": "1440px" },
    "navHeightSm":   { "$value": "64px" },
    "navHeightLg":   { "$value": "80px" }
  }
}
